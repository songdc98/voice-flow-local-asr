{
  "paste_after_stop": true,
  "sample_rate": 16000,
  "channels": 1,
  "audio_device": null,
  "prefer_system_default_input": true,
  "input_probe": {
    "enabled": true,
    "seconds": 0.25,
    "threshold": 0.00001
  },
  "preferred_input_names": [
    "DJI Mic Mini",
    "DJI Mic",
    "Mic Mini",
    "DJI"
  ],
  "max_record_seconds": 1800,
  "min_record_seconds": 0.35,
  "notify": false,
  "audio_ducking": {
    "enabled": true,
    "factor": 0.0,
    "restore_on_stop": true
  },
  "hud": {
    "enabled": true,
    "size": 112,
    "position": "bottom_center",
    "margin_x": 34,
    "margin_y": 64,
    "poll_interval_seconds": 0.06
  },
  "retention": {
    "keep_audio": true,
    "max_audio_files": 3,
    "keep_failed_audio": true,
    "keep_logs": true,
    "max_logs": 500,
    "max_tmp_files": 20,
    "max_age_days": 7
  },
  "hotwords": [
    "Qwen",
    "Qwen3-ASR",
    "Whisper large-v3",
    "API",
    "OpenAI",
    "ChatGPT",
    "transformer",
    "LLM",
    "ASR",
    "Python",
    "PyTorch",
    "MLX"
  ],
  "corrections": {
    "Queen A S R": "Qwen ASR",
    "Queen ASR": "Qwen ASR",
    "Qwen A S R": "Qwen ASR",
    "A P I": "API",
    "Open I": "OpenAI",
    "open eye": "OpenAI",
    "withpe": "Whisper",
    "withper": "Whisper"
  },
  "asr": {
    "model": "mlx-community/Qwen3-ASR-1.7B-8bit",
    "language": "zh",
    "max_tokens": 8192,
    "chunk_duration": 30,
    "long_audio_split_seconds": 360,
    "timeout_seconds": 3600
  }
}
